# Supabase — safe to expose to the browser (anon key is designed for client use)
VITE_SUPABASE_URL=https://clgjsuzpuqhtbhyrfpte.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI - BACKEND ONLY - Never expose to frontend
OPENAI_API_KEY=sk-your-openai-key-here

# Stripe - Backend only
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# GitHub - For OAuth and repo access, backend only
GITHUB_APP_PRIVATE_KEY=your-github-private-key
GITHUB_APP_ID=your-github-app-id

# Feature flags
VITE_ENABLE_PAYMENTS=false
VITE_ENABLE_AI_FEATURES=false
VITE_ENABLE_REPO_SCAN=false

# Fill in all five to activate B2 cloud storage.
#
# Find these in B2 Console → Buckets → [your bucket] → Bucket Settings
# Use a restricted Application Key scoped to this bucket only.
VITE_B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
VITE_B2_REGION=us-west-004
VITE_B2_APPLICATION_KEY_ID=
VITE_B2_APPLICATION_KEY=
VITE_B2_BUCKET_NAME=