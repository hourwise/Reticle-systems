# Firebase web app config - safe to expose to the browser
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-optional-measurement-id

# Firebase Admin / Cloud Functions - BACKEND ONLY - Never expose to frontend
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

# OpenAI - BACKEND ONLY - Never expose to frontend
OPENAI_API_KEY=sk-your-openai-key-here

# Stripe - Backend only
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# GitHub - For OAuth and repo access, backend only
GITHUB_APP_PRIVATE_KEY=your-github-private-key
GITHUB_APP_ID=your-github-app-id

# Feature flags
VITE_ENABLE_PAYMENTS=false
VITE_ENABLE_AI_FEATURES=false
VITE_ENABLE_REPO_SCAN=false
